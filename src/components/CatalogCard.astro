---
import Icon from "./Icon.astro";
import type { Category } from "../data/site";
import { categoryImages, whatsappLink } from "../data/site";

interface Props {
  category: Category;
  compact?: boolean;
}

const { category, compact = false } = Astro.props;
const image = categoryImages[category.slug as keyof typeof categoryImages];
---

<article
  data-catalog-card
  data-catalog-image-card
  class:list={[
    "catalog-image-card card-link group relative flex flex-col justify-end overflow-hidden rounded-xl border border-border bg-deep",
    compact ? "h-72" : "h-80",
  ]}
>
  <img
    src={image}
    alt={category.title}
    loading="lazy"
    decoding="async"
    width="1024"
    height="768"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/60 to-deep/10"></div>

  <div class="relative p-5">
    <span class="inline-block rounded border border-white/25 bg-white/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-white/90 backdrop-blur-sm">
      {category.tag}
    </span>
    <h2 class="mt-3 font-display text-lg font-semibold text-white">{category.title}</h2>
    <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-white/75">{category.description}</p>

    <div class:list={["mt-4 flex items-center gap-3 pt-4", !compact && "justify-between border-t border-white/15"]}>
      <a
        href={`/catalogos/${category.slug}`}
        class="catalog-card-link inline-flex items-center gap-1.5 text-sm font-semibold text-white transition-colors duration-200 ease-out hover:text-brand"
      >
        Ver catálogo <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-1" />
      </a>
      {!compact && (
        <a
          href={whatsappLink(`Hola, quisiera información sobre la categoría ${category.title}.`)}
          target="_blank"
          rel="noopener noreferrer"
          class="catalog-info-link rounded-md px-2 py-1 text-xs font-medium text-white/70 hover:text-white"
        >
          Solicitar información
        </a>
      )}
    </div>
  </div>
</article>
