---
import Icon from "./Icon.astro";
import type { Category } from "../data/site";
import { whatsappLink } from "../data/site";

interface Props {
  category: Category;
  compact?: boolean;
}

const { category, compact = false } = Astro.props;
---

<article data-catalog-card class="lift-card card-link flex h-full flex-col rounded-lg border border-border bg-card p-5">
  <div class="flex items-center">
    <span class="rounded border border-border px-1.5 py-0.5 text-[10px] font-semibold uppercase text-muted-foreground">
      {category.tag}
    </span>
  </div>
  <h2 class="mt-3 font-display text-base font-semibold text-deep">{category.title}</h2>
  <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{category.description}</p>

  <div class:list={["mt-auto flex items-center gap-3 pt-4", !compact && "justify-between border-t border-border"]}>
    <a
      href={`/catalogos/${category.slug}`}
      class="link-primary-soft inline-flex items-center gap-1.5 text-sm font-semibold"
    >
      Ver catálogo <Icon name="arrow-right" class="h-4 w-4" />
    </a>
    {!compact && (
      <a
        href={whatsappLink(`Hola, quisiera información sobre la categoría ${category.title}.`)}
        target="_blank"
        rel="noopener noreferrer"
        class="catalog-info-link rounded-md px-2 py-1 text-xs font-medium"
      >
        Solicitar información
      </a>
    )}
  </div>
</article>
