---
import Icon from "./Icon.astro";
import type { Category } from "../data/site";
import { categoryImages } from "../data/site";

interface Props {
  category: Category;
  compact?: boolean;
}

const { category, compact = false } = Astro.props;
const image = categoryImages[category.slug as keyof typeof categoryImages];
---

<a
  href={`/catalogos/${category.slug}`}
  aria-label={`Ver catálogo de ${category.title}`}
  data-catalog-card
  data-catalog-image-card
  class:list={[
    "catalog-image-card card-link group relative flex flex-col justify-end overflow-hidden rounded-xl border border-border bg-deep",
    compact ? "h-72" : "h-80",
  ]}
>
  <img
    src={image}
    alt={category.title}
    loading="lazy"
    decoding="async"
    width="1024"
    height="768"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/60 to-deep/10"></div>

  <div class="relative p-5">
    <span class="catalog-chip inline-block rounded border bg-primary/15 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-white/90 backdrop-blur-sm">
      {category.tag}
    </span>
    <h2 class="mt-3 font-display text-lg font-semibold text-white">{category.title}</h2>
    <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-white/75">{category.description}</p>

    <div class:list={["mt-4 flex items-center gap-3 pt-4", !compact && "catalog-card-divider border-t"]}>
      <span class="catalog-card-link inline-flex items-center gap-1.5 text-sm font-semibold text-white transition-colors duration-200 ease-out group-hover:text-brand">
        Ver catálogo <Icon name="arrow-right" class="catalog-card-arrow h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-1" />
      </span>
    </div>
  </div>
</a>
