---
import Icon from "./Icon.astro";
import { categories, footerNav, images, site, whatsappLink } from "../data/site";
---

<footer class="relative overflow-hidden bg-ink text-[#D9E1F1]">
  <div aria-hidden="true" class="brand-medallion pointer-events-none absolute -left-28 -bottom-28 h-[360px] w-[360px] rounded-full opacity-30"></div>
  <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-4 lg:px-8">
    <div>
      <a href="/" class="flex items-center gap-2.5">
        <img
          src={images.logoCircular}
          alt={`${site.name} logo`}
          width="40"
          height="40"
          class="h-10 w-10 rounded-full ring-1 ring-primary/35"
        />
        <span class="font-display text-lg font-semibold text-white">Chaco <span class="text-brand">Implantes</span></span>
      </a>
      <p class="mt-4 text-sm text-[#D9E1F1]">{site.activity}</p>
      <p class="mt-4 font-accent text-base text-white">{site.tagline}</p>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold text-white">Categorías</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          categories.slice(0, 6).map((category) => (
            <li>
              <a href={`/catalogos/${category.slug}`} class="footer-link">
                {category.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold text-white">Secciones</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {footerNav.map((item) => (
          <li>
            <a href={item.href} class="footer-link">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold text-white">Contacto</h2>
      <ul class="mt-4 space-y-3 text-sm text-[#D9E1F1]">
        <li class="flex items-start gap-2">
          <Icon name="phone" class="mt-0.5 h-4 w-4 shrink-0 text-brand" />
          <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="footer-link">
            {site.phoneDisplay}
          </a>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="map-pin" class="mt-0.5 h-4 w-4 shrink-0 text-brand" />
          <span>{site.address}</span>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="instagram" class="mt-0.5 h-4 w-4 shrink-0 text-brand" />
          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="footer-link">
            {site.instagramHandle}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-4 py-6 text-center text-xs text-[#D9E1F1]/70 sm:px-6 lg:px-8">
      © 2026 {site.name}. {site.tagline}.
    </div>
  </div>
</footer>
