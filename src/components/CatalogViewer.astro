---
import Icon from "./Icon.astro";
import { whatsappLink } from "../data/site";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  image: string;
  whatsappMessage: string;
}

const { title, eyebrow, description, image, whatsappMessage } = Astro.props;
---

<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1fr_340px]">
  <section class="premium-card rounded-xl border p-4 sm:p-6" data-catalog-viewer>
    <div class="relative overflow-hidden rounded-xl border border-border bg-deep">
      <div class="relative aspect-[4/3]">
        <img
          src={image}
          alt={title}
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/35 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-6">
          <p class="text-xs font-bold uppercase text-brand">{eyebrow}</p>
          <p class="mt-1 font-display text-2xl font-black text-white">{title}</p>
        </div>
      </div>
    </div>
    <p class="mt-5 flex items-start gap-2 text-sm text-muted-foreground">
      <Icon name="file-text" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
      El catálogo técnico completo en PDF se envía a pedido, con medidas, componentes y referencias del sistema.
    </p>
  </section>

  <aside class="space-y-5">
    <section class="premium-card rounded-xl border p-6">
      <p class="text-xs font-bold uppercase text-primary">{eyebrow}</p>
      <h2 class="mt-1 font-display text-2xl font-black text-deep">{title}</h2>
      <p class="mt-3 text-sm text-muted-foreground">{description}</p>

      <dl class="mt-5 space-y-2 border-t border-border pt-5 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-muted-foreground">Tipo de producto</dt>
          <dd class="text-right font-semibold text-deep">{eyebrow}</dd>
        </div>
      </dl>
    </section>

    <div class="space-y-3">
      <a
        href="/contacto"
        class="btn-secondary flex w-full items-center justify-center gap-2 rounded-md px-4 py-3 text-sm font-bold"
      >
        <Icon name="file-text" class="h-4 w-4" /> Solicitar catálogo PDF
      </a>
      <a
        href={whatsappLink(whatsappMessage)}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary flex w-full items-center justify-center gap-2 rounded-md px-4 py-3 text-sm font-bold"
      >
        <Icon name="message-circle" class="h-4 w-4" /> Contactar por WhatsApp
      </a>
    </div>
  </aside>
</div>
