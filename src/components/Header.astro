---
import Icon from "./Icon.astro";
import { images, nav, site, wa } from "../data/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
const isActive = (href: string) => {
  const cleanHref = href.split("#")[0].replace(/\/$/, "") || "/";
  return cleanHref === "/" ? currentPath === "/" : currentPath === cleanHref;
};
---

<header
  data-site-header
  data-home-header={isHome ? "true" : "false"}
  data-transparent={isHome ? "true" : "false"}
  class="site-header fixed inset-x-0 top-0 z-50 border-b transition-[background-color,border-color,box-shadow,backdrop-filter] duration-300"
>
  <div class="site-header-inner flex w-full items-center justify-between px-4 transition-[height] duration-300 lg:px-10">
    <a href="/" class="group flex items-center gap-3" aria-label={`${site.name} - inicio`}>
      <img
        src={images.logoCircularWhite}
        alt={`${site.name} logo`}
        width="56"
        height="56"
        class="site-logo-mark rounded-full"
      />
      <span class="flex flex-col leading-none">
        <span class="site-logo-title font-display text-lg font-extrabold uppercase">
          Chaco <span class="text-brand">Implantes</span>
        </span>
        <span class="site-logo-subtitle mt-0.5 text-[11px] font-semibold uppercase">
          PRODUCTOS TRAUMATOLÓGICOS
        </span>
      </span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-3 lg:flex" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            data-active={isActive(item.href) ? "true" : "false"}
            class:list={[
              "nav-link px-3 py-2 text-sm font-semibold uppercase transition-[color,opacity] duration-200 ease-out",
              isActive(item.href) && "font-bold",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={wa.sitio}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary hidden items-center gap-2 rounded-md px-4 py-2 text-sm font-semibold sm:inline-flex"
      >
        <Icon name="message-circle" class="h-4 w-4" />
        WhatsApp
      </a>
      <button
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        data-menu-toggle
        class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-md border border-primary-glow/40 bg-primary text-white shadow-[0_0_18px_rgba(0,136,255,0.35)] lg:hidden"
      >
        <span class="menu-icon-frame">
          <span data-menu-open-icon class="menu-icon-state"><Icon name="menu" class="h-5 w-5" /></span>
          <span data-menu-close-icon class="menu-icon-state"><Icon name="x" class="h-5 w-5" /></span>
        </span>
      </button>
    </div>
  </div>

  <nav data-mobile-menu data-state="closed" class="mobile-menu overflow-hidden border-t border-primary/30 lg:hidden" aria-label="Principal movil" aria-hidden="true" inert>
    <div class="space-y-1 px-4 py-4">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            data-active={isActive(item.href) ? "true" : "false"}
            class:list={[
              "nav-link-mobile block rounded-md px-3 py-2.5 text-sm font-semibold transition-[background-color,color,opacity] duration-200 ease-out hover:bg-primary/10",
              isActive(item.href) && "bg-primary/15 font-bold",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={wa.sitio}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-2 flex items-center justify-center gap-2 rounded-md px-4 py-2.5 text-sm font-semibold"
      >
        <Icon name="message-circle" class="h-4 w-4" />
        WhatsApp
      </a>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  let menuCloseTimer: number | undefined;

  const syncHeader = () => {
    if (!(header instanceof HTMLElement)) return;
    const isHomeHeader = header.dataset.homeHeader === "true";
    const menuOpen = toggle?.getAttribute("aria-expanded") === "true";
    const transparent = isHomeHeader && window.scrollY < 60 && !menuOpen;
    header.dataset.menuOpen = String(menuOpen);
    header.dataset.transparent = String(transparent);
  };

  const setMenuState = (open: boolean) => {
    if (!(toggle instanceof HTMLElement) || !(menu instanceof HTMLElement)) return;
    window.clearTimeout(menuCloseTimer);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Cerrar menu" : "Abrir menu");
    menu.setAttribute("aria-hidden", String(!open));

    if (open) {
      menu.removeAttribute("inert");
      menu.dataset.state = "open";
    } else {
      menu.setAttribute("inert", "");
      menu.dataset.state = reduceMotion.matches ? "closed" : "closing";
      if (!reduceMotion.matches) {
        menuCloseTimer = window.setTimeout(() => {
          menu.dataset.state = "closed";
        }, 160);
      }
    }

    syncHeader();
  };

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    setMenuState(!expanded);
  });

  window.addEventListener("scroll", syncHeader, { passive: true });
  syncHeader();
</script>
