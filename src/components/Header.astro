---
import Icon from "./Icon.astro";
import { images, nav, site, whatsappLink } from "../data/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const cleanHref = href.split("#")[0].replace(/\/$/, "") || "/";
  return cleanHref === "/" ? currentPath === "/" : currentPath === cleanHref;
};
---

<header class="sticky top-0 z-50 border-b border-border bg-background/85 backdrop-blur-md">
  <div class="flex h-16 w-full items-center justify-between px-4 lg:px-10">
    <a href="/" class="flex items-center gap-3" aria-label={`${site.name} - inicio`}>
      <img
        src={images.logoCircular}
        alt={`${site.name} logo`}
        width="40"
        height="40"
        class="h-9 w-9 rounded-full lg:h-10 lg:w-10"
      />
      <span class="flex flex-col leading-none">
        <span class="font-display text-lg font-semibold text-deep">
          Chaco <span class="text-primary">Implantes</span>
        </span>
        <span class="mt-0.5 text-[11px] font-medium uppercase text-muted-foreground">
          Traumatología
        </span>
      </span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-2 lg:flex" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            data-active={isActive(item.href) ? "true" : "false"}
            class:list={[
              "nav-link rounded-md px-3 py-2 text-sm font-medium transition-[color,opacity] duration-200 ease-out",
              isActive(item.href) && "font-semibold",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={whatsappLink("Hola, me comunico desde el sitio de Chaco Implantes.")}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary hidden items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-deep sm:inline-flex"
      >
        <Icon name="message-circle" class="h-4 w-4" />
        WhatsApp
      </a>
      <button
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        data-menu-toggle
        class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-md text-deep lg:hidden"
      >
        <span data-menu-open-icon><Icon name="menu" class="h-5 w-5" /></span>
        <span data-menu-close-icon class="hidden"><Icon name="x" class="h-5 w-5" /></span>
      </button>
    </div>
  </div>

  <nav data-mobile-menu class="hidden overflow-hidden border-t border-border bg-background lg:hidden" aria-label="Principal móvil">
    <div class="space-y-1 px-4 py-4">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            data-active={isActive(item.href) ? "true" : "false"}
            class:list={[
              "nav-link-mobile block rounded-md px-3 py-2.5 text-sm font-medium transition-[background-color,color,opacity] duration-200 ease-out hover:bg-secondary",
              isActive(item.href) && "bg-secondary font-semibold",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={whatsappLink("Hola, me comunico desde el sitio de Chaco Implantes.")}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-2 flex items-center justify-center gap-2 rounded-md bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground"
      >
        <Icon name="message-circle" class="h-4 w-4" />
        WhatsApp
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    toggle.querySelector("[data-menu-open-icon]")?.classList.toggle("hidden", !expanded);
    toggle.querySelector("[data-menu-close-icon]")?.classList.toggle("hidden", expanded);
    menu?.classList.toggle("hidden", expanded);
  });
</script>
