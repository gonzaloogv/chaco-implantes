---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { GALLERY_PAGE_SIZE, gallery, galleryFilters, videos } from "../data/site";
---

<BaseLayout
  title="Galería — Chaco Implantes"
  description="Galería de productos, instrumental, quirófano y eventos de Chaco Implantes."
  canonicalPath="/galeria"
>
  <section class="page-hero-dark border-b border-white/10 px-4 pb-14 pt-32 text-white sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h1 class="font-display text-4xl font-black sm:text-5xl">Galería</h1>
      <p class="mt-3 max-w-2xl text-brand">
        Productos, instrumental y actividades con profesionales e instituciones.
      </p>
    </div>
  </section>

  <section class="page-surface">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8" data-gallery-page-size={GALLERY_PAGE_SIZE}>

    {videos.length > 0 && (
      <div class="mt-6 flex flex-col gap-3 rounded-xl bg-deep p-5 text-deep-foreground sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <div class="accent-icon-chip flex h-10 w-10 shrink-0 items-center justify-center rounded-full border">
            <Icon name="play-circle" class="h-5 w-5" />
          </div>
          <div>
            <p class="font-display text-sm font-semibold">¿Buscás material audiovisual?</p>
            <p class="text-xs text-white/70">Encontrá videos institucionales y de productos.</p>
          </div>
        </div>
        <a href="/videos" class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-deep transition-colors hover:bg-brand/90">
          <Icon name="play-circle" class="h-4 w-4" /> Ver videos
        </a>
      </div>
    )}

    <div class="mt-8 flex flex-wrap items-center gap-2" data-gallery-filters>
      {["Todos", ...galleryFilters].map((filter) => (
        <button
          type="button"
          data-filter={filter}
          class:list={[
            "gallery-filter rounded-full border px-4 py-1.5 text-sm font-medium",
            filter === "Todos" ? "gallery-filter-active" : "gallery-filter-idle",
          ]}
        >
          {filter}
        </button>
      ))}
    </div>

    <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4" data-gallery-grid>
      {gallery.map((item, index) => (
        <button
          type="button"
          data-gallery-item
          data-index={index}
          data-category={item.category}
          data-image={item.full}
          data-alt={item.alt}
          aria-label={`Ampliar: ${item.alt} (imagen ${index + 1} de ${gallery.length})`}
          class:list={[
            "gallery-card card-link group flex flex-col overflow-hidden rounded-lg border border-border bg-card text-left",
            index >= GALLERY_PAGE_SIZE && "hidden",
          ]}
        >
          <span class="gallery-thumb relative block aspect-[3/2] overflow-hidden bg-secondary/50">
            <span class="img-spinner" data-thumb-spinner aria-hidden="true"></span>
            <img
              src={item.thumb}
              alt={item.alt}
              loading={index < GALLERY_PAGE_SIZE ? "eager" : "lazy"}
              fetchpriority={index < 4 ? "high" : "auto"}
              decoding="async"
              draggable={false}
              width="600"
              height="400"
              class="relative h-full w-full object-cover transition-transform duration-200 ease-out"
            />
          </span>
          <span class="flex items-center gap-2 px-3 py-2.5">
            <span class="h-3 w-px shrink-0 bg-brand"></span>
            <span class="line-clamp-1 text-xs font-medium text-deep">{item.alt}</span>
          </span>
        </button>
      ))}
    </div>

    <div class="mt-10 flex justify-center" data-load-more-wrap>
      <button
        type="button"
        data-load-more
        class="inline-flex items-center justify-center rounded-md border border-border bg-card px-6 py-3 text-sm font-semibold text-deep transition-colors hover:border-primary hover:text-primary"
      >
        Cargar más <span data-load-more-count class="ml-1">({gallery.length - GALLERY_PAGE_SIZE})</span>
      </button>
    </div>
  </div>
  </section>

  <dialog data-lightbox role="dialog" aria-modal="true" aria-labelledby="lightbox-title" class="lightbox-dialog fixed z-[80] text-deep-foreground">
    <button type="button" data-lightbox-close aria-label="Cerrar" class="icon-button absolute right-4 top-4 z-10 inline-flex h-10 w-10 items-center justify-center rounded-md text-deep-foreground hover:bg-primary/20">
      <Icon name="x" class="h-6 w-6" />
    </button>
    <button type="button" data-lightbox-prev aria-label="Imagen anterior" class="icon-button absolute left-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full text-deep-foreground hover:bg-primary/20 sm:left-6">
      <Icon name="chevron-left" class="h-6 w-6" />
    </button>
    <button type="button" data-lightbox-next aria-label="Imagen siguiente" class="icon-button absolute right-3 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full text-deep-foreground hover:bg-primary/20 sm:right-6">
      <Icon name="chevron-right" class="h-6 w-6" />
    </button>
    <figure class="lightbox-panel max-h-[85vh] max-w-3xl overflow-hidden rounded-xl bg-card text-deep">
      <span class="relative block bg-card">
        <img data-lightbox-image alt="" draggable={false} class="lightbox-image max-h-[78vh] w-full object-contain" />
        <span class="img-spinner lightbox-spinner" data-lightbox-spinner aria-hidden="true"></span>
      </span>
      <figcaption class="space-y-0.5 px-4 py-3 text-sm">
        <span id="lightbox-title" data-lightbox-caption-title class="block font-semibold text-deep"></span>
        <span data-lightbox-caption-category class="block text-xs text-muted-foreground"></span>
      </figcaption>
    </figure>
  </dialog>
</BaseLayout>

<script>
  const page = document.querySelector("[data-gallery-page-size]");
  const pageSize = Number(page?.getAttribute("data-gallery-page-size") || "12");
  const filterWrap = document.querySelector("[data-gallery-filters]");
  const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
  const galleryGrid = document.querySelector("[data-gallery-grid]");
  const galleryItems = Array.from(document.querySelectorAll("[data-gallery-item]"));
  const loadMore = document.querySelector("[data-load-more]");
  const loadMoreWrap = document.querySelector("[data-load-more-wrap]");
  const loadMoreCount = document.querySelector("[data-load-more-count]");

  // Oculta el spinner de cada miniatura cuando su imagen termina de cargar (o falla)
  const markThumbLoaded = (image: HTMLImageElement) => {
    const wrap = image.closest(".gallery-thumb");
    if (wrap instanceof HTMLElement) wrap.dataset.loaded = "true";
  };
  galleryItems.forEach((item) => {
    const image = item.querySelector("img");
    if (!(image instanceof HTMLImageElement)) return;
    if (image.complete && image.naturalWidth > 0) {
      markThumbLoaded(image);
      return;
    }
    image.addEventListener("load", () => markThumbLoaded(image), { once: true });
    image.addEventListener("error", () => markThumbLoaded(image), { once: true });
  });
  const lightbox = document.querySelector("[data-lightbox]");
  const lightboxPanel = document.querySelector(".lightbox-panel");
  const lightboxImage = document.querySelector("[data-lightbox-image]");
  const lightboxCaptionTitle = document.querySelector("[data-lightbox-caption-title]");
  const lightboxCaptionCategory = document.querySelector("[data-lightbox-caption-category]");
  const close = document.querySelector("[data-lightbox-close]");
  const prev = document.querySelector("[data-lightbox-prev]");
  const next = document.querySelector("[data-lightbox-next]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  // Red de seguridad para el spinner: si la imagen visible ya cargó, ocultalo aunque
  // el decode() previo no haya resuelto (algunos renderers lo dejan colgado).
  const clearLightboxLoading = () => {
    if (lightboxPanel instanceof HTMLElement) lightboxPanel.removeAttribute("data-lightbox-loading");
  };
  if (lightboxImage instanceof HTMLImageElement) {
    lightboxImage.addEventListener("load", clearLightboxLoading);
    lightboxImage.addEventListener("error", clearLightboxLoading);
  }

  let activeFilter = "Todos";
  let visible = pageSize;
  let activeIndex = -1;
  let lastTrigger: HTMLElement | null = null;
  let galleryFilterTimer: number | undefined;
  let lightboxRequestId = 0;
  const prefetchedThumbs = new Set<string>();
  const prefetchedImages: HTMLImageElement[] = [];
  const prefetchedLightboxImages = new Map<string, HTMLImageElement>();

  type IdleWindow = Window &
    typeof globalThis & {
      requestIdleCallback?: (callback: () => void, options?: { timeout: number }) => number;
    };

  const normalizeFilter = (value: string) =>
    value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase();

  const findFilterButton = (filter: string) =>
    filterButtons.find((item) => item instanceof HTMLElement && normalizeFilter(item.dataset.filter || "") === normalizeFilter(filter));

  const filteredItems = () =>
    galleryItems.filter((item) => item instanceof HTMLElement && (activeFilter === "Todos" || item.dataset.category === activeFilter));

  const syncGallery = () => {
    const items = filteredItems();
    galleryItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) return;
      const filtered = activeFilter === "Todos" || item.dataset.category === activeFilter;
      const index = items.indexOf(item);
      item.classList.toggle("hidden", !filtered || index >= visible);
    });

    const remaining = Math.max(items.length - visible, 0);
    loadMoreWrap?.classList.toggle("hidden", remaining === 0);
    if (loadMoreCount) loadMoreCount.textContent = `(${remaining})`;
  };

  const pulseGallery = () => {
    if (!(galleryGrid instanceof HTMLElement) || reduceMotion.matches) return;
    window.clearTimeout(galleryFilterTimer);
    galleryGrid.setAttribute("data-filtering", "true");
    galleryFilterTimer = window.setTimeout(() => {
      galleryGrid.removeAttribute("data-filtering");
    }, 140);
  };

  const requestWhenIdle = (callback: () => void) => {
    const idleWindow = window as IdleWindow;
    if (typeof idleWindow.requestIdleCallback === "function") {
      idleWindow.requestIdleCallback(callback, { timeout: 1200 });
      return;
    }
    window.setTimeout(callback, 180);
  };

  const getItemThumb = (item: Element) => {
    const image = item.querySelector("img");
    return image instanceof HTMLImageElement ? image.currentSrc || image.src : "";
  };

  const getItemFullImage = (item: HTMLElement) => item.dataset.image || "";

  const prefetchThumb = (url: string) => {
    if (!url || prefetchedThumbs.has(url)) return;
    prefetchedThumbs.add(url);
    const warmImage = new Image();
    warmImage.decoding = "async";
    warmImage.src = url;
    prefetchedImages.push(warmImage);
    if (prefetchedImages.length > pageSize * 3) prefetchedImages.shift();
  };

  const prefetchNextBatch = () => {
    const nextItems = filteredItems().slice(visible, visible + pageSize);
    if (!nextItems.length) return;

    requestWhenIdle(() => {
      nextItems.forEach((item) => {
        if (item instanceof HTMLElement) prefetchThumb(getItemThumb(item));
      });
    });
  };

  const trimLightboxImageCache = (latestUrl: string) => {
    if (prefetchedLightboxImages.size <= pageSize) return;
    const oldestUrl = prefetchedLightboxImages.keys().next().value;
    if (typeof oldestUrl === "string" && oldestUrl !== latestUrl) {
      prefetchedLightboxImages.delete(oldestUrl);
    }
  };

  const getLightboxImage = (url: string) => {
    const cachedImage = prefetchedLightboxImages.get(url);
    if (cachedImage) return cachedImage;

    const image = new Image();
    image.decoding = "async";
    image.src = url;
    prefetchedLightboxImages.set(url, image);
    trimLightboxImageCache(url);
    return image;
  };

  const waitForImage = (image: HTMLImageElement) =>
    new Promise<void>((resolve) => {
      if (image.complete) {
        resolve();
        return;
      }

      image.addEventListener("load", () => resolve(), { once: true });
      image.addEventListener("error", () => resolve(), { once: true });
    });

  const loadLightboxImage = async (item: HTMLElement) => {
    const url = getItemFullImage(item);
    if (!url) return;

    const image = getLightboxImage(url);
    // Esperamos a que la imagen esté lista, pero corremos decode() en carrera con el
    // evento load real: si decode() se cuelga (algunos renderers lo hacen), el load
    // igual resuelve y el visor nunca queda atrapado en estado de carga.
    const loaded = waitForImage(image);
    if (typeof image.decode === "function") {
      try {
        await Promise.race([image.decode(), loaded]);
        return;
      } catch {
        // Broken or interrupted image requests should not trap the lightbox in loading state.
      }
    }

    await loaded;
  };

  const prefetchLightboxItem = (item: Element | undefined) => {
    if (!(item instanceof HTMLElement)) return;
    const url = getItemFullImage(item);
    if (!url) return;

    const image = getLightboxImage(url);
    if (typeof image.decode === "function") {
      image.decode().catch(() => undefined);
    }
  };

  const prefetchLightboxNeighbors = (index: number) => {
    const items = filteredItems();
    if (!items.length) return;

    requestWhenIdle(() => {
      [index, index - 1, index + 1].forEach((position) => {
        const item = items[(position + items.length) % items.length];
        prefetchLightboxItem(item);
      });
    });
  };

  const prioritizeVisibleImages = () => {
    filteredItems()
      .slice(0, pageSize)
      .forEach((item, index) => {
        if (!(item instanceof HTMLElement)) return;
        const image = item.querySelector("img");
        if (!(image instanceof HTMLImageElement)) return;
        image.loading = "eager";
        image.setAttribute("fetchpriority", index < 4 ? "high" : "auto");
      });
  };

  const setActiveFilter = (filter: string, shouldPulse = true) => {
    const button = findFilterButton(filter) || findFilterButton("Todos");
    if (!(button instanceof HTMLElement)) return;

    activeFilter = button.dataset.filter || "Todos";
    visible = pageSize;

    filterButtons.forEach((item) => {
      const active = item === button;
      item.classList.toggle("gallery-filter-active", active);
      item.classList.toggle("gallery-filter-idle", !active);
    });

    syncGallery();
    prioritizeVisibleImages();
    if (shouldPulse) pulseGallery();
    prefetchNextBatch();
  };

  const setLightboxContent = (item: HTMLElement) => {
    if (lightboxImage instanceof HTMLImageElement) {
      lightboxImage.src = item.dataset.image || "";
      lightboxImage.alt = item.dataset.alt || "";
    }
    if (lightboxCaptionTitle) {
      lightboxCaptionTitle.textContent = item.dataset.alt || "Imagen de galería";
    }
    if (lightboxCaptionCategory) {
      lightboxCaptionCategory.textContent = item.dataset.category ? `Categoría: ${item.dataset.category}` : "";
    }
  };

  const openLightbox = async (index: number) => {
    const items = filteredItems();
    const item = items[index];
    if (!(item instanceof HTMLElement)) return;
    const wasOpen = lightbox instanceof HTMLDialogElement && lightbox.open;
    const requestId = ++lightboxRequestId;
    activeIndex = index;

    if (lightboxPanel instanceof HTMLElement) {
      lightboxPanel.setAttribute("data-lightbox-loading", "true");
    }

    if (!wasOpen) {
      setLightboxContent(item);
    }

    if (lightbox instanceof HTMLDialogElement && !lightbox.open) {
      document.body.style.overflow = "hidden";
      lightbox.showModal();
      if (close instanceof HTMLElement) close.focus({ preventScroll: true });
    }

    await loadLightboxImage(item);
    if (requestId !== lightboxRequestId) return;

    if (wasOpen) {
      setLightboxContent(item);
    }
    if (lightboxPanel instanceof HTMLElement) {
      lightboxPanel.removeAttribute("data-lightbox-loading");
    }
    prefetchLightboxNeighbors(index);
  };

  const go = (delta: number) => {
    const items = filteredItems();
    if (!items.length || activeIndex < 0) return;
    openLightbox((activeIndex + delta + items.length) % items.length);
  };

  filterWrap?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-filter]");
    if (!(button instanceof HTMLElement)) return;
    setActiveFilter(button.dataset.filter || "Todos");
  });

  galleryItems.forEach((item) => {
    item.addEventListener("click", () => {
      const items = filteredItems();
      lastTrigger = item instanceof HTMLElement ? item : null;
      openLightbox(items.indexOf(item));
    });
  });

  loadMore?.addEventListener("click", () => {
    visible += pageSize;
    syncGallery();
    prioritizeVisibleImages();
    prefetchNextBatch();
  });

  const hideLightbox = () => {
    activeIndex = -1;
    lightboxRequestId += 1;
    if (lightboxPanel instanceof HTMLElement) {
      lightboxPanel.removeAttribute("data-lightbox-loading");
    }
    if (lightbox instanceof HTMLDialogElement && lightbox.open) {
      lightbox.close();
    }
    document.body.style.overflow = "";
    if (lastTrigger instanceof HTMLElement) lastTrigger.focus({ preventScroll: true });
    lastTrigger = null;
  };

  close?.addEventListener("click", hideLightbox);
  lightbox?.addEventListener("cancel", (event) => {
    event.preventDefault();
    hideLightbox();
  });
  prev?.addEventListener("click", (event) => {
    event.stopPropagation();
    go(-1);
  });
  next?.addEventListener("click", (event) => {
    event.stopPropagation();
    go(1);
  });
  lightbox?.addEventListener("click", (event) => {
    if (event.target === lightbox) hideLightbox();
  });
  document.addEventListener("keydown", (event) => {
    if (!(lightbox instanceof HTMLDialogElement) || !lightbox.open) return;
    if (event.key === "ArrowLeft") go(-1);
    if (event.key === "ArrowRight") go(1);
  });

  const initialParams = new URLSearchParams(window.location.search);
  const initialFilter = initialParams.get("categoria") || initialParams.get("category") || initialParams.get("filter") || "Todos";
  setActiveFilter(initialFilter, false);
</script>
