---
import BaseLayout from "../layouts/BaseLayout.astro";
import CatalogCard from "../components/CatalogCard.astro";
import Icon from "../components/Icon.astro";
import {
  categoryImages,
  featuredCategories,
  featuredEvent,
  heroSlides,
  images,
  professionalBlocks,
  supplierSystems,
  valuePillars,
  videos,
  wa,
} from "../data/site";
---

<BaseLayout canonicalPath="/">
  <section id="inicio" data-hero-carousel class="hero-shell relative flex min-h-screen overflow-hidden">
    <h1 class="sr-only">Prótesis, implantes e instrumental para equipos quirúrgicos</h1>
    {heroSlides.map((slide, index) => (
      <img
        src={slide.image}
        alt={slide.imageAlt}
        fetchpriority={index === 0 ? "high" : "auto"}
        loading={index === 0 ? "eager" : "lazy"}
        decoding="async"
        data-hero-bg
        data-active={index === 0 ? "true" : "false"}
        class="hero-bg-slide hero-photo-glow pointer-events-none absolute inset-0 h-full w-full object-cover"
      />
    ))}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,#0f172a_0%,rgba(15,23,42,0.92)_32%,rgba(25,35,56,0.52)_58%,rgba(25,35,56,0.05)_100%)]"></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_22%_38%,rgba(74,144,196,0.22),transparent_28rem)]"></div>

    <div class="relative z-10 mx-auto flex w-full max-w-7xl items-center px-4 pb-12 pt-32 sm:px-6 lg:px-8 lg:pb-20 lg:pt-36">
      <div class="w-full max-w-3xl">
        <div class="relative min-h-[35rem] sm:min-h-[34rem] lg:min-h-[36rem]">
          {heroSlides.map((slide, index) => (
            <article
              data-hero-slide
              data-active={index === 0 ? "true" : "false"}
              aria-hidden={index === 0 ? "false" : "true"}
              class:list={[
                "hero-slide absolute inset-0 flex flex-col justify-center transition-[opacity,transform] duration-300 ease-out",
                index !== 0 && "pointer-events-none",
              ]}
            >
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-primary/35 bg-primary/15 px-3 py-2 text-xs font-bold uppercase text-brand shadow-[0_0_24px_rgba(74,144,196,0.18)]">
                <span class="h-2 w-2 rounded-full bg-primary shadow-[0_0_10px_rgba(74,144,196,0.9)]"></span>
                {slide.eyebrow}
              </span>
              <h2 class="mt-5 font-display text-4xl font-black leading-[1.02] text-white sm:text-5xl lg:text-7xl">
                {slide.title}
              </h2>
              <p class="mt-5 max-w-2xl text-base leading-relaxed text-brand sm:text-xl">{slide.text}</p>
              <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <a href={slide.href} class="btn-primary-soft inline-flex w-full items-center justify-center gap-2 rounded-md px-6 py-3.5 text-sm font-bold sm:w-auto">
                  {slide.ctaLabel} <Icon name="arrow-right" class="h-4 w-4" />
                </a>
                <a
                  href={wa.general}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-glass-outline inline-flex w-full items-center justify-center gap-2 rounded-md px-6 py-3.5 text-sm font-bold sm:w-auto"
                >
                  <Icon name="message-circle" class="h-4 w-4" /> Contactar por WhatsApp
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
    <div class="hero-dot-controls absolute bottom-6 left-1/2 z-20 -translate-x-1/2 lg:bottom-10" role="group" aria-label="Control de slides del hero">
      <div class="flex items-center gap-2 py-2">
        {heroSlides.map((slide, index) => (
          <button
            type="button"
            data-hero-dot
            data-index={index}
            aria-label={`Ver ${slide.title}`}
            aria-pressed={index === 0 ? "true" : "false"}
            class="hero-dot h-2.5 rounded-full transition-[width,background-color,opacity] duration-200 ease-out"
          ></button>
        ))}
        <button
          type="button"
          data-hero-autoplay
          aria-pressed="false"
          aria-label="Pausar rotación automática"
          class="ml-2 inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white transition-colors duration-200 ease-out hover:bg-white/20"
        >
          <span data-hero-pause-icon><Icon name="pause" class="h-3.5 w-3.5" /></span>
          <span data-hero-play-icon class="hidden"><Icon name="play" class="h-3.5 w-3.5" /></span>
        </button>
      </div>
    </div>
  </section>

  <section data-value-pillars class="value-pillars-band px-4 py-4 sm:px-6 lg:px-8">
    <h2 class="sr-only">Diferenciales de Chaco Implantes</h2>
    <div class="mx-auto grid max-w-7xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {valuePillars.map((pillar) => (
        <article data-value-pillar class="value-pillar-card flex min-h-20 items-center gap-3 rounded-lg border px-4 py-3">
          <span class="value-pillar-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-md text-white">
            <Icon name={pillar.icon} class="h-5 w-5" />
          </span>
          <p class="value-pillar-label text-sm font-semibold leading-snug">{pillar.label}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-dark-gradient">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-primary">
            <span class="h-px w-6 bg-brand"></span>
            Catálogo por especialidad
          </span>
          <h2 class="mt-3 font-display text-2xl font-black text-deep sm:text-4xl">Líneas de productos</h2>
          <p class="mt-2 max-w-2xl text-muted-foreground">Prótesis, implantes e instrumental organizados por especialidad.</p>
        </div>
        <a href="/catalogos" class="link-primary-soft inline-flex items-center gap-1.5 text-sm font-semibold">
          Ver todos los catálogos <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featuredCategories.map((category) => <CatalogCard category={category} compact />)}
      </div>
    </div>
  </section>

  <section data-suppliers-section class="suppliers-section">
    <div class="mx-auto max-w-5xl px-4 py-14 text-white sm:px-6 sm:py-16 lg:px-8">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-primary-glow">
          <span class="h-px w-6 bg-primary-glow"></span>
          Proveedores y sistemas
        </span>
        <h2 class="mt-3 font-display text-2xl font-black sm:text-3xl">Líneas destacadas para resolver cada procedimiento</h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-brand sm:text-base">
          Combinamos sistemas internacionales, líneas exclusivas y productos nacionales para dar respuesta comercial, disponibilidad e instrumental según cada caso.
        </p>
      </div>

      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {supplierSystems.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="supplier-brand-card flex h-20 items-center justify-center rounded-lg border px-5 py-3"
            aria-label={`Visitar sitio de ${item.name}`}
          >
            <img
              src={item.logo}
              alt={item.logoAlt}
              width={item.logoWidth}
              height={item.logoHeight}
              loading="eager"
              decoding="async"
              class:list={["supplier-logo", item.logoClass]}
            />
          </a>
        ))}
        <article class="supplier-brand-card supplier-brand-card-muted flex h-20 items-center justify-center rounded-lg border px-5 py-3">
          <span class="font-display text-sm font-semibold text-brand">+ otras líneas</span>
        </article>
      </div>
    </div>
  </section>

  <section id="profesionales" class="scroll-mt-20 border-b border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl font-bold text-deep sm:text-3xl">
          Trabajamos con traumatólogos, cirujanos, clínicas y sanatorios
        </h2>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          professionalBlocks.map((block) => (
            <article class="lift-card flex items-start gap-4 rounded-lg border border-border bg-card p-5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-secondary text-primary ring-1 ring-border">
                <Icon name={block.icon} class="h-4 w-4" />
              </div>
              <div>
                <h3 class="font-display text-base font-semibold text-deep">{block.title}</h3>
                <p class="mt-1 text-sm text-muted-foreground">{block.text}</p>
              </div>
            </article>
          ))
        }
      </div>

    </div>
  </section>

  <section class="bg-ink">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 sm:py-14 lg:px-8">
      <div class="reveal">
        <span class="mx-auto block h-px w-10 bg-brand"></span>
        <p class="mt-5 font-display text-xl font-black leading-snug text-white sm:text-3xl">
          Calidad que se siente. Confianza que se nota.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-white/75 sm:text-base">
          Acompañamos a clínicas y sanatorios con logística confiable de prótesis, implantes e instrumental.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-border bg-surface-2/45">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl font-bold text-deep sm:text-3xl">{videos.length > 0 ? "Galería y videos" : "Galería"}</h2>
        <p class="mt-2 text-muted-foreground">
          {videos.length > 0
            ? "Recorré nuestras fotos de productos e instrumental, y nuestros videos institucionales."
            : "Recorré nuestras fotos de productos, instrumental y actividades profesionales."}
        </p>
      </div>

      <div class:list={["mt-8 grid gap-5", videos.length > 0 && "sm:grid-cols-2"]}>
        <a href="/galeria" class="catalog-image-card card-link group relative flex h-60 flex-col justify-end overflow-hidden rounded-xl border border-border bg-deep">
          <img
            src={categoryImages["instrumental-quirurgico"]}
            alt="Galería de productos e instrumental"
            loading="lazy"
            decoding="async"
            width="1024"
            height="768"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/55 to-deep/5"></div>
          <div class="relative p-6">
            <h3 class="font-display text-lg font-semibold text-white">Galería de imágenes</h3>
            <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
              <Icon name="images" class="h-4 w-4" /> Ver galería
              <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-1" />
            </span>
          </div>
        </a>

        {videos.length > 0 && (
          <a href="/videos" class="catalog-image-card card-link group relative flex h-60 flex-col justify-end overflow-hidden rounded-xl border border-border bg-deep">
            <img
              src={images.quirofano}
              alt="Videos institucionales"
              loading="lazy"
              decoding="async"
              width="1024"
              height="768"
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/55 to-deep/5"></div>
            <div class="relative p-6">
              <h3 class="font-display text-lg font-semibold text-white">Videos</h3>
              <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
                <Icon name="play-circle" class="h-4 w-4" /> Ver videos
                <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-1" />
              </span>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>

  <section data-commercial-band="primary" class="bg-primary">
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-5 px-4 py-12 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <div class="max-w-xl">
        <h2 class="font-display text-xl font-semibold text-white sm:text-2xl">Consultas comerciales e institucionales</h2>
        <p class="mt-2 text-sm text-white">
          Coordinamos pedidos, disponibilidad y suministro de prótesis, implantes e instrumental para profesionales, clínicas y sanatorios.
        </p>
      </div>
      <div class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto">
        <a
          href={wa.general}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-light inline-flex items-center justify-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold"
        >
          <Icon name="message-circle" class="h-4 w-4" /> WhatsApp
        </a>
        <a href="/catalogos" class="btn-glass-outline inline-flex items-center justify-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold">
          Ver catálogos <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl font-bold text-deep sm:text-3xl">Eventos y capacitaciones</h2>
      </div>

      <article class="reveal mt-8 overflow-hidden rounded-2xl border border-border bg-card shadow-sm md:grid md:grid-cols-2">
        <div class="relative aspect-[16/10] md:aspect-auto">
          <img
            src={featuredEvent.image}
            alt={featuredEvent.imageAlt}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="flex flex-col justify-center p-6 sm:p-8">
          <span class="inline-flex w-fit items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-primary ring-1 ring-border">
            Actividad profesional
          </span>
          <h3 class="mt-3 font-display text-xl font-semibold text-deep">
            {featuredEvent.title}
          </h3>
          <p class="mt-1 flex items-center gap-1.5 text-sm text-muted-foreground">
            <Icon name="map-pin" class="h-4 w-4 text-primary" /> {featuredEvent.venue}
          </p>
          <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
            {featuredEvent.description}
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a
              href={wa.congreso}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary inline-flex w-fit items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold"
            >
              <Icon name="message-circle" class="h-4 w-4" /> Consultanos
            </a>
            <a href="/eventos" class="btn-secondary inline-flex w-fit items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold">
              Ver todos los eventos <Icon name="arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </article>

    </div>
  </section>
</BaseLayout>

<script>
  const carousel = document.querySelector("[data-hero-carousel]");
  if (carousel instanceof HTMLElement) {
    const slides = Array.from(carousel.querySelectorAll("[data-hero-slide]"));
    const backgrounds = Array.from(carousel.querySelectorAll("[data-hero-bg]"));
    const dots = Array.from(carousel.querySelectorAll("[data-hero-dot]"));
    const autoplayToggle = carousel.querySelector("[data-hero-autoplay]");
    const pauseIcon = carousel.querySelector("[data-hero-pause-icon]");
    const playIcon = carousel.querySelector("[data-hero-play-icon]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const AUTO_ADVANCE_MS = 6500;

    let active = 0;
    let timer: number | undefined;
    let manuallyPaused = false;
    let pointerInside = false;
    let inView = true;

    const setActive = (index: number) => {
      active = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === active;
        if (slide instanceof HTMLElement) {
          slide.dataset.active = String(isActive);
          slide.setAttribute("aria-hidden", String(!isActive));
          slide.classList.toggle("pointer-events-none", !isActive);
        }
      });
      backgrounds.forEach((background, backgroundIndex) => {
        if (background instanceof HTMLElement) {
          background.dataset.active = String(backgroundIndex === active);
        }
      });
      dots.forEach((dot, dotIndex) => {
        dot.setAttribute("aria-pressed", String(dotIndex === active));
      });
    };

    const stopAuto = () => {
      if (timer !== undefined) {
        window.clearInterval(timer);
        timer = undefined;
      }
    };

    // Un solo punto de decisión: solo rota si nada lo frena
    const syncAuto = () => {
      stopAuto();
      if (manuallyPaused || pointerInside || !inView || reduceMotion.matches) return;
      timer = window.setInterval(() => setActive(active + 1), AUTO_ADVANCE_MS);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        setActive(index);
        syncAuto();
      });
    });

    autoplayToggle?.addEventListener("click", () => {
      manuallyPaused = !manuallyPaused;
      autoplayToggle.setAttribute("aria-pressed", String(manuallyPaused));
      autoplayToggle.setAttribute(
        "aria-label",
        manuallyPaused ? "Reanudar rotación automática" : "Pausar rotación automática",
      );
      pauseIcon?.classList.toggle("hidden", manuallyPaused);
      playIcon?.classList.toggle("hidden", !manuallyPaused);
      syncAuto();
    });

    carousel.addEventListener("pointerenter", () => {
      pointerInside = true;
      syncAuto();
    });
    carousel.addEventListener("pointerleave", () => {
      pointerInside = false;
      syncAuto();
    });

    new IntersectionObserver((entries) => {
      inView = entries.some((entry) => entry.isIntersecting);
      syncAuto();
    }).observe(carousel);

    reduceMotion.addEventListener("change", syncAuto);
    syncAuto();
  }
</script>
