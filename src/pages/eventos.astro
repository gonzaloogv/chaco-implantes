---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { featuredEvent, images, wa } from "../data/site";
---

<BaseLayout
  title="Capacitaciones y novedades — Chaco Implantes"
  description="Capacitaciones, jornadas y novedades de Chaco Implantes para profesionales e instituciones de salud en Resistencia, Chaco."
  canonicalPath="/eventos"
>
  <section data-eventos-page class="page-hero-dark border-b border-white/10 px-4 pb-14 pt-32 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div>
        <h1 class="font-display text-4xl font-black sm:text-5xl">Capacitaciones y novedades</h1>
        <p class="mt-3 max-w-2xl text-brand">
          Presencia profesional, actualización y acompañamiento a equipos médicos e instituciones de salud.
        </p>
      </div>

      <div class="catalog-image-card relative hidden h-64 overflow-hidden rounded-xl border border-primary/20 bg-deep lg:block">
        <img
          src={images.heroEventos}
          alt="Chaco Implantes en eventos profesionales"
          loading="lazy"
          decoding="async"
          width="1400"
          height="900"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/35 to-transparent"></div>
        <div class="relative flex h-full items-end p-6">
          <p class="max-w-sm text-sm font-semibold text-white">
            Novedades, congresos y espacios de intercambio junto a profesionales del rubro.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-surface">
    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <article data-featured-event class="premium-card overflow-hidden rounded-xl border md:grid md:grid-cols-2">
        <div class="relative aspect-[16/10] md:aspect-auto">
          <img
            src={featuredEvent.image}
            alt={featuredEvent.imageAlt}
            loading="lazy"
            decoding="async"
            width="1400"
            height="1000"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="flex flex-col justify-center p-6 sm:p-8">
          <span class="inline-flex w-fit items-center rounded-full bg-secondary px-3 py-1 text-xs font-bold uppercase text-primary ring-1 ring-border">
            {featuredEvent.badge}
          </span>
          <h2 class="mt-4 font-display text-2xl font-black leading-tight text-deep">
            {featuredEvent.title}
          </h2>
          <p class="mt-2 flex items-center gap-1.5 text-sm text-muted-foreground">
            <Icon name="map-pin" class="h-4 w-4 text-primary" /> {featuredEvent.venue}
          </p>
          <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
            {featuredEvent.description}
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a
              href={wa.congreso}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary inline-flex w-fit items-center gap-2 rounded-md px-5 py-2.5 text-sm font-bold"
            >
              <Icon name="message-circle" class="h-4 w-4" /> Consultanos
            </a>
            <a href="/galeria?categoria=Eventos" class="btn-secondary inline-flex w-fit items-center gap-2 rounded-md px-5 py-2.5 text-sm font-bold">
              Ver imágenes <Icon name="arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </article>

      <div class="mt-8 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
        <section class="dark-card rounded-xl border p-6 text-white">
          <div class="accent-icon-chip flex h-11 w-11 items-center justify-center rounded-lg border text-brand">
            <Icon name="calendar-clock" class="h-5 w-5" />
          </div>
          <h2 class="mt-5 font-display text-xl font-black">Próximas actividades</h2>
          <p class="mt-2 text-sm leading-relaxed text-brand">
            Publicaremos nuevas fechas, jornadas y capacitaciones para equipos profesionales cuando estén confirmadas.
          </p>
        </section>

        <section class="premium-card rounded-xl border p-6">
          <h2 class="font-display text-xl font-black text-deep">Consultas sobre capacitaciones</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Escribinos para conocer novedades, coordinar una visita técnica o solicitar información sobre líneas de producto para instituciones.
          </p>
          <a
            href={wa.capacitaciones}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary mt-5 inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-bold"
          >
            <Icon name="message-circle" class="h-4 w-4" /> Consultar por WhatsApp
          </a>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
