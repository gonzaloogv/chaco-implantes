---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CatalogCard from "../../components/CatalogCard.astro";
import { categories } from "../../data/site";
---

<BaseLayout
  title="Catálogos — Chaco Implantes"
  description="Catálogos de cadera, rodilla, columna, maxilofacial, osteosíntesis e instrumental quirúrgico."
  canonicalPath="/catalogos"
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="max-w-2xl">
      <h1 class="font-display text-3xl font-bold text-deep sm:text-4xl">Catálogos</h1>
      <p class="mt-3 text-sm text-muted-foreground">
        Líneas de prótesis, implantes e instrumental por especialidad.
      </p>
    </header>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => <CatalogCard category={category} />)}
    </div>
  </div>
</BaseLayout>
