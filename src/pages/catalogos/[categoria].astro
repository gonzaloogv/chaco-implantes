---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { categories, whatsappLink } from "../../data/site";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { categoria: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
---

<BaseLayout
  title={`${category.title} — Catálogo | Chaco Implantes`}
  description={category.description}
  canonicalPath={`/catalogos/${category.slug}`}
>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <a href="/catalogos" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-primary">
      <Icon name="arrow-left" class="h-4 w-4" /> Volver a catálogos
    </a>

    <div class="mt-6 grid gap-8 lg:grid-cols-[1fr_320px]">
      <section class="rounded-lg border border-border bg-card p-4 sm:p-6" data-catalog-viewer data-total={category.pages}>
        <div class="relative mx-auto aspect-[3/4] max-w-md overflow-hidden rounded-lg border border-border bg-secondary/50">
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-8 text-center">
            <Icon name="file-text" class="h-10 w-10 text-primary/70" />
            <p class="font-display text-lg font-semibold text-deep">{category.title}</p>
            <p class="text-sm text-muted-foreground">Vista previa de página <span data-current-page>1</span></p>
            <p class="mt-2 text-xs text-muted-foreground/80">Catálogo técnico — contenido de muestra</p>
          </div>
        </div>

        <div class="mt-5 flex items-center justify-center gap-4">
          <button
            type="button"
            data-prev-page
            disabled
            class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-md border border-border text-deep hover:border-primary hover:text-primary disabled:opacity-40 disabled:hover:border-border disabled:hover:text-deep"
            aria-label="Página anterior"
          >
            <Icon name="chevron-left" class="h-5 w-5" />
          </button>
          <span class="text-sm font-medium text-muted-foreground">
            <span data-page-count>1</span> / {category.pages}
          </span>
          <button
            type="button"
            data-next-page
            class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-md border border-border text-deep hover:border-primary hover:text-primary disabled:opacity-40 disabled:hover:border-border disabled:hover:text-deep"
            aria-label="Página siguiente"
          >
            <Icon name="chevron-right" class="h-5 w-5" />
          </button>
        </div>
      </section>

      <aside class="space-y-5">
        <section class="rounded-lg border border-border bg-card p-6">
          <p class="text-xs font-medium uppercase text-primary">{category.type}</p>
          <h1 class="mt-1 font-display text-2xl font-bold text-deep">{category.title}</h1>
          <p class="mt-3 text-sm text-muted-foreground">{category.description}</p>

          <dl class="mt-5 space-y-2 border-t border-border pt-5 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-muted-foreground">Tipo de producto</dt>
              <dd class="text-right font-medium text-deep">{category.type}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Páginas</dt>
              <dd class="font-medium text-deep">{category.pages}</dd>
            </div>
          </dl>
        </section>

        <div class="space-y-3">
          <a
            href="/contacto"
            class="btn-secondary flex w-full items-center justify-center gap-2 rounded-md px-4 py-3 text-sm font-semibold"
          >
            <Icon name="download" class="h-4 w-4" /> Descargar PDF
          </a>
          <a
            href={whatsappLink(`Hola, quisiera información sobre el catálogo de ${category.title}.`)}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary flex w-full items-center justify-center gap-2 rounded-md bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground hover:bg-deep"
          >
            <Icon name="message-circle" class="h-4 w-4" /> Contactar por WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  const viewer = document.querySelector("[data-catalog-viewer]");
  if (viewer instanceof HTMLElement) {
    const total = Number(viewer.dataset.total || "1");
    let page = 1;
    const current = viewer.querySelector("[data-current-page]");
    const count = viewer.querySelector("[data-page-count]");
    const prev = viewer.querySelector("[data-prev-page]");
    const next = viewer.querySelector("[data-next-page]");

    const update = () => {
      if (current) current.textContent = String(page);
      if (count) count.textContent = String(page);
      if (prev instanceof HTMLButtonElement) prev.disabled = page <= 1;
      if (next instanceof HTMLButtonElement) next.disabled = page >= total;
    };

    prev?.addEventListener("click", () => {
      page = Math.max(1, page - 1);
      update();
    });
    next?.addEventListener("click", () => {
      page = Math.min(total, page + 1);
      update();
    });
  }
</script>
