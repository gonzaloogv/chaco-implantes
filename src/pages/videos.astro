---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { videos } from "../data/site";
---

<BaseLayout
  title="Videos — Chaco Implantes"
  description="Videos institucionales y de productos de Chaco Implantes. Reproducción bajo demanda."
  canonicalPath="/videos"
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="max-w-2xl">
      <h1 class="font-display text-3xl font-bold text-deep sm:text-4xl">Videos</h1>
      <p class="mt-3 text-sm text-muted-foreground">
        Material institucional y de productos. Los videos se cargan sólo al reproducir.
      </p>
    </header>

    <div class="mt-6 flex flex-col gap-3 rounded-xl bg-deep p-5 text-deep-foreground sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/10">
          <Icon name="images" class="h-5 w-5" />
        </div>
        <div>
          <p class="font-display text-sm font-semibold">¿Preferís ver imágenes?</p>
          <p class="text-xs text-white/70">Recorré la galería de productos, instrumental y eventos.</p>
        </div>
      </div>
      <a href="/galeria" class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-deep transition-colors hover:bg-brand/90">
        <Icon name="images" class="h-4 w-4" /> Ver galería
      </a>
    </div>

    {videos.length === 0 ? (
      <div class="mt-10 flex flex-col items-start gap-5 rounded-lg border border-dashed border-border bg-card px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-secondary text-primary ring-1 ring-border">
            <Icon name="calendar-clock" class="h-5 w-5" />
          </div>
          <div>
            <p class="font-display text-base font-semibold text-deep">
              Pronto publicaremos nuestros videos institucionales y de productos.
            </p>
            <p class="mt-1 text-sm text-muted-foreground">
              Mientras tanto, podés recorrer la galería de imágenes.
            </p>
          </div>
        </div>
        <a href="/galeria" class="btn-primary inline-flex shrink-0 items-center justify-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold">
          <Icon name="images" class="h-4 w-4" /> Ir a la galería
        </a>
      </div>
    ) : (
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {videos.map((video) => (
          <article class="overflow-hidden rounded-lg border border-border bg-card">
            <div class="relative aspect-video bg-secondary/50">
              <video
                src={video.src}
                poster={video.poster}
                controls
                preload="none"
                playsinline
                class="h-full w-full object-cover"
              ></video>
            </div>
            <div class="px-4 py-3">
              <h2 class="font-display text-sm font-semibold text-deep">{video.title}</h2>
              <p class="mt-0.5 text-xs text-muted-foreground">{video.category}</p>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
