---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { categoryImages, galleryFilters, videos } from "../data/site";
---

<BaseLayout
  title="Videos — Chaco Implantes"
  description="Videos institucionales y de productos de Chaco Implantes. Reproducción bajo demanda."
  canonicalPath="/videos"
>
  <section data-videos-page class="page-hero-dark border-b border-white/10 px-4 pb-14 pt-32 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div>
        <h1 class="font-display text-4xl font-black sm:text-5xl">Videos</h1>
        <p class="mt-3 max-w-2xl text-brand">
          Un espacio para videos institucionales, productos e instrumental. El contenido audiovisual se publicará bajo demanda para profesionales e instituciones.
        </p>
      </div>

      <div class="catalog-image-card relative hidden h-64 overflow-hidden rounded-xl border border-primary/20 bg-deep lg:block">
        <img
          src={categoryImages["instrumental-quirurgico"]}
          alt="Instrumental quirúrgico para productos traumatológicos"
          loading="lazy"
          decoding="async"
          width="1024"
          height="768"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-deep via-deep/45 to-transparent"></div>
        <div class="relative flex h-full items-end p-6">
          <p class="max-w-sm text-sm font-semibold text-white">
            Próximamente: recorridos de producto, material institucional y novedades de líneas destacadas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-surface">
    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="dark-card flex flex-col gap-5 rounded-xl border p-5 text-white sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <div class="accent-icon-chip flex h-10 w-10 shrink-0 items-center justify-center rounded-full border text-brand">
            <Icon name="images" class="h-5 w-5" />
          </div>
          <div>
            <p class="font-display text-sm font-bold">También podés recorrer la galería</p>
            <p class="text-xs text-brand">Productos, instrumental, quirófano y presencia profesional.</p>
          </div>
        </div>
        <a href="/galeria" class="btn-primary inline-flex items-center justify-center gap-2 rounded-md px-5 py-2.5 text-sm font-bold">
          <Icon name="images" class="h-4 w-4" /> Ver galería
        </a>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-2" data-video-filters>
        {["Todos", ...galleryFilters].map((filter) => (
          <button
            type="button"
            data-video-filter={filter}
            aria-pressed={filter === "Todos" ? "true" : "false"}
            class:list={[
              "gallery-filter rounded-full border px-4 py-1.5 text-sm font-medium",
              filter === "Todos" ? "gallery-filter-active" : "gallery-filter-idle",
            ]}
          >
            {filter}
          </button>
        ))}
      </div>

      {videos.length === 0 ? (
        <div data-videos-empty class="premium-card mt-8 flex flex-col items-start gap-5 rounded-xl border px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-secondary text-primary ring-1 ring-border">
              <Icon name="calendar-clock" class="h-5 w-5" />
            </div>
            <div>
              <p data-videos-empty-title class="font-display text-base font-bold text-deep">
                Pronto publicaremos nuestros videos institucionales y de productos.
              </p>
              <p data-videos-empty-description class="mt-1 max-w-xl text-sm text-muted-foreground">
                Mientras tanto, podés explorar imágenes de productos, instrumental y actividades profesionales.
              </p>
            </div>
          </div>
          <a href="/galeria" class="btn-primary inline-flex shrink-0 items-center justify-center gap-2 rounded-md px-5 py-2.5 text-sm font-bold">
            <Icon name="images" class="h-4 w-4" /> Ir a la galería
          </a>
        </div>
      ) : (
        <>
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-videos-grid>
            {videos.map((video) => (
              <article data-video-item data-category={video.category} class="premium-card overflow-hidden rounded-xl border">
                <div class="relative aspect-video bg-secondary/50">
                  <video
                    src={video.src}
                    poster={video.poster}
                    controls
                    preload="none"
                    playsinline
                    class="h-full w-full object-cover"
                  ></video>
                </div>
                <div class="px-4 py-3">
                  <h2 class="font-display text-sm font-semibold text-deep">{video.title}</h2>
                  <p class="mt-0.5 text-xs text-muted-foreground">{video.category}</p>
                </div>
              </article>
            ))}
          </div>
          <div data-videos-empty class="premium-card mt-8 hidden rounded-xl border px-6 py-10 text-center">
            <p data-videos-empty-title class="font-display text-base font-bold text-deep"></p>
            <p data-videos-empty-description class="mt-1 text-sm text-muted-foreground"></p>
          </div>
        </>
      )}

      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        <article class="premium-card rounded-xl border p-6">
          <p class="font-display text-lg font-black text-deep">Contenido orientado a consulta profesional</p>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Los videos se organizan para acompañar consultas comerciales, líneas de producto y material institucional.
          </p>
        </article>
        <article class="premium-card rounded-xl border p-6">
          <p class="font-display text-lg font-black text-deep">Carga bajo demanda</p>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Cada video se cargará únicamente al reproducir para mantener una navegación liviana y rápida.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterWrap = document.querySelector("[data-video-filters]");
  const filterButtons = Array.from(document.querySelectorAll("[data-video-filter]"));
  const videoItems = Array.from(document.querySelectorAll("[data-video-item]"));
  const emptyState = document.querySelector("[data-videos-empty]");
  const emptyTitle = emptyState?.querySelector("[data-videos-empty-title]");
  const emptyDescription = emptyState?.querySelector("[data-videos-empty-description]");
  const defaultEmptyTitle = emptyTitle?.textContent?.trim() || "Pronto publicaremos nuevos videos.";
  const defaultEmptyDescription = emptyDescription?.textContent?.trim() || "Podés recorrer la galería mientras incorporamos nuevo material.";

  const normalizeFilter = (value: string) =>
    value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase();

  const findFilterButton = (filter: string) =>
    filterButtons.find(
      (item) =>
        item instanceof HTMLElement &&
        normalizeFilter(item.dataset.videoFilter || "") === normalizeFilter(filter),
    );

  const updateEmptyState = (filter: string, hasVisibleVideos: boolean) => {
    if (!(emptyState instanceof HTMLElement)) return;

    const hasVideos = videoItems.length > 0;
    emptyState.classList.toggle("hidden", hasVideos && hasVisibleVideos);

    if (!hasVideos && filter === "Todos") {
      if (emptyTitle) emptyTitle.textContent = defaultEmptyTitle;
      if (emptyDescription) emptyDescription.textContent = defaultEmptyDescription;
      return;
    }

    if (emptyTitle) {
      emptyTitle.textContent = `Todavía no hay videos de ${filter.toLowerCase()}.`;
    }
    if (emptyDescription) {
      emptyDescription.textContent = "Podés elegir otra categoría o recorrer la galería mientras incorporamos nuevo material.";
    }
  };

  const setActiveFilter = (filter: string) => {
    const button = findFilterButton(filter) || findFilterButton("Todos");
    if (!(button instanceof HTMLElement)) return;

    const activeFilter = button.dataset.videoFilter || "Todos";
    let visibleVideos = 0;

    filterButtons.forEach((item) => {
      if (!(item instanceof HTMLElement)) return;
      const active = item === button;
      item.classList.toggle("gallery-filter-active", active);
      item.classList.toggle("gallery-filter-idle", !active);
      item.setAttribute("aria-pressed", String(active));
    });

    videoItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) return;
      const visible = activeFilter === "Todos" || item.dataset.category === activeFilter;
      item.classList.toggle("hidden", !visible);
      if (visible) visibleVideos += 1;

      if (!visible) {
        const video = item.querySelector("video");
        if (video instanceof HTMLVideoElement) video.pause();
      }
    });

    updateEmptyState(activeFilter, visibleVideos > 0);
  };

  filterWrap?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-video-filter]");
    if (!(button instanceof HTMLElement)) return;
    setActiveFilter(button.dataset.videoFilter || "Todos");
  });

  const initialParams = new URLSearchParams(window.location.search);
  const initialFilter = initialParams.get("categoria") || initialParams.get("category") || initialParams.get("filter") || "Todos";
  setActiveFilter(initialFilter);
</script>
